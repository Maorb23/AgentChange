{
  "description": "Passive AgentChange lifecycle evidence capture.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "agentchange-hook capture --plugin-root \"${PLUGIN_ROOT}\"",
            "commandWindows": "agentchange-hook capture --plugin-root \"${PLUGIN_ROOT}\"",
            "timeout": 10,
            "statusMessage": "Recording AgentChange session start"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "agentchange-hook capture --plugin-root \"${PLUGIN_ROOT}\"",
            "commandWindows": "agentchange-hook capture --plugin-root \"${PLUGIN_ROOT}\"",
            "timeout": 10,
            "statusMessage": "Recording AgentChange tool attempt"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "agentchange-hook capture --plugin-root \"${PLUGIN_ROOT}\"",
            "commandWindows": "agentchange-hook capture --plugin-root \"${PLUGIN_ROOT}\"",
            "timeout": 10,
            "statusMessage": "Recording AgentChange tool result"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "agentchange-hook capture --plugin-root \"${PLUGIN_ROOT}\"",
            "commandWindows": "agentchange-hook capture --plugin-root \"${PLUGIN_ROOT}\"",
            "timeout": 10,
            "statusMessage": "Recording AgentChange user prompt"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "agentchange-hook capture --plugin-root \"${PLUGIN_ROOT}\"",
            "commandWindows": "agentchange-hook capture --plugin-root \"${PLUGIN_ROOT}\"",
            "timeout": 10,
            "statusMessage": "Recording AgentChange permission request"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "agentchange-hook finalize --plugin-root \"${PLUGIN_ROOT}\"",
            "commandWindows": "agentchange-hook finalize --plugin-root \"${PLUGIN_ROOT}\"",
            "timeout": 10,
            "statusMessage": "Finalizing AgentChange turn receipt"
          }
        ]
      }
    ]
  }
}
